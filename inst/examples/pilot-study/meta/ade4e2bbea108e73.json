    "footnotes": {
      "footnote_0001": {
        "text": [
          "NOTES: Only subjects with baseline results are included in the summary."
        ],
        "order": 1
      },
      "footnote_0002": {
        "text": [
          "There were no subjects with abnormal low values at baseline."
        ],
        "order": 2
      },
      "footnote_0003": {
        "text": [
          "[1] A subject is counted only once for each analyte. A change will be considered shifting from normal at baseline to abnormal or from abnormal at baseline to normal at any visit during the treatment. The treatment period is defined as any planned visit after Week 0 (Visit 3), up to and including Week 24 (Visit 12)."
        ],
        "order": 3
      },
      "footnote_0004": {
        "text": [
          "[2] CMH test for general association, controlling for status at baseline."
        ],
        "order": 4
      }
